  "validationCheckpoints": {
    "1_account_creation": {
      "title": "Account Creation & Email Verification",
      "steps": [
        "Navigate to /auth page",
        "Click 'Create Account' for each role type",
        "Fill out registration form with test data",
        "Submit registration",
        "Check email for verification link",
        "Click verification link", 
        "Confirm account is activated"
      ],
      "expectedResults": [
        "Registration form accepts valid data",
        "Verification email delivered within 60 seconds",
        "Verification link is functional and secure",
        "Account status changes to verified",
        "User can sign in after verification"
      ]
    },
    "2_signin_process": {
      "title": "Sign-in Authentication",
      "steps": [
        "Navigate to /auth page",
        "Enter verified email and password",
        "Click sign in button",
        "Verify redirection to appropriate dashboard"
      ],
      "expectedResults": [
        "Authentication succeeds with valid credentials",
        "Role-appropriate dashboard loads",
        "Session persists across page reloads",
        "Invalid credentials are rejected with clear error"
      ]
    },
    "3_dashboard_access": {
      "title": "Role-based Dashboard Access",
      "steps": [
        "Sign in as each role type",
        "Verify dashboard features match role permissions",
        "Test role-specific functionality",
        "Verify no access to unauthorized features"
      ],
      "expectedResults": [
        "Each role sees appropriate dashboard",
        "Role permissions strictly enforced",
        "No cross-role data access",
        "Admin features only accessible to admins"
      ]
    },
    "4_language_switching": {
      "title": "Multi-language Support",
      "steps": [
        "Access any page of the application",
        "Use language selector in header",
        "Switch to Spanish (ES)",
        "Switch to Portuguese (PT)", 
        "Switch to Romanian (RO)",
        "Return to English (EN)",
        "Verify translations across different pages"
      ],
      "expectedResults": [
        "Language changes immediately",
        "All UI elements translate correctly",
        "Language preference persists",
        "No untranslated content visible"
      ]
    },
    "5_data_protection": {
      "title": "Data Protection & Privacy",
      "steps": [
        "Access hotel pages without authentication",
        "Sign in as regular user and re-access",
        "Sign in as hotel owner and access own hotel",
        "Sign in as admin and access all data"
      ],
      "expectedResults": [
        "Public view shows only non-sensitive data",
        "Contact details hidden from public",
        "Users only see own data",
        "Owners only access owned hotels",
        "Admins have appropriate full access"
      ]
    },
    "6_hotel_registration": {
      "title": "Hotel Registration Flow",
      "steps": [
        "Access hotel registration page",
        "Complete registration with test hotel data",
        "Submit registration form",
        "Check email for verification",
        "Verify email and activate hotel account",
        "Sign in to hotel dashboard",
        "Verify hotel appears as 'pending approval'"
      ],
      "expectedResults": [
        "Registration form validation works correctly",
        "All required fields are enforced",
        "Email verification is mandatory",
        "Hotel dashboard becomes accessible",
        "Hotel status shows as pending",
        "Admin receives notification of new hotel"
      ]
    },
