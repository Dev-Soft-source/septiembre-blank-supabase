#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔒 Running pre-commit security checks..."

# Lint and type check
echo "📝 Running lint and type check..."
npm run lint
npx tsc --noEmit

# Check for forbidden patterns
echo "🔍 Checking for forbidden raw SQL patterns..."
if grep -r "supabase\.query\|\.sql\`\|execute.*SELECT\|execute.*INSERT\|execute.*UPDATE\|execute.*DELETE" src/ --exclude-dir=node_modules 2>/dev/null; then
  echo "❌ Found potential raw SQL usage. Use Supabase client methods instead."
  exit 1
fi

# Quick secret scan
echo "🔐 Quick secret scan..."
if grep -r -i "sk_live_\|pk_live_\|api_key.*=.*['\"][a-zA-Z0-9]{20,}\|password.*=.*['\"][^'\"]{8,}" src/ 2>/dev/null | head -5; then
  echo "⚠️  Potential secrets found. Please review and add '// OK: safe usage' if false positive."
  echo "Commit blocked for security review."
  exit 1
fi

# Check staged files only for performance
echo "📋 Checking staged files for security issues..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -n "$STAGED_FILES" ]; then
  echo "Staged files: $STAGED_FILES"
  # Additional checks on staged files could go here
fi

echo "✅ Pre-commit security checks passed!"