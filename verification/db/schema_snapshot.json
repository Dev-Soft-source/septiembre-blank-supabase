{
  "tables": [
    "availability_packages","hotels","bookings","booking_commissions","free_nights_rewards","hotel_availability","hotel_referrals","hotel_themes","hotel_images"
  ],
  "constraints_summary": {
    "availability_packages": [
      "CHECK duration_days IN (8,15,22,29)",
      "CHECK end_date = start_date + (duration_days - 1)",
      "CHECK available_rooms <= total_rooms",
      "CHECK available_rooms >= 0",
      "FK hotel_id -> hotels.id"
    ],
    "bookings": [
      "FK user_id -> profiles.id",
      "FK hotel_id -> hotels.id",
      "FK package_id -> availability_packages.id (SET NULL)",
      "CHECK commission_source_type IN ('association','promoter','hotel_referrer')",
      "CHECK (commission_source_type, commission_source_id) both NULL or both NOT NULL"
    ],
    "booking_commissions": [
      "UNIQUE (booking_id)",
      "FK booking_id -> bookings.id"
    ],
    "free_nights_rewards": [
      "CHECK owner_type IN ('hotel','user')",
      "CHECK status IN ('available','redeemed','expired')",
      "CHECK source IN ('hotel_approved','user_referral')",
      "UNIQUE (source, source_id, owner_type, owner_id)",
      "FK owner_id -> profiles.id"
    ]
  },
  "triggers": [
    {"table":"hotels","trigger":"hotel_approval_free_nights","function":"create_hotel_free_nights_reward"},
    {"table":"hotels","trigger":"user_referral_free_nights","function":"create_user_referral_reward"},
    {"table":"availability_packages","trigger":"prevent_package_overlap","function":"check_package_overlap"},
    {"table":"availability_packages","trigger":"update_availability_packages_updated_at","function":"update_updated_at_column"},
    {"table":"hotel_availability","trigger":"trigger_update_hotel_available_months","function":"update_hotel_available_months"},
    {"table":"bookings","trigger":"trg_calculate_booking_commission_after_insert","function":"calculate_booking_commission_after_insert"},
    {"table":"bookings","trigger":"trigger_calculate_leader_commission","function":"calculate_leader_commission"}
  ],
  "indexes": {
    "availability_packages": [
      "idx_availability_packages_hotel_date (hotel_id, start_date, end_date)",
      "idx_availability_packages_future_dates (hotel_id, start_date)"
    ],
    "booking_commissions": ["booking_commissions_booking_id_unique (booking_id)"],
    "free_nights_rewards": [
      "idx_free_nights_rewards_owner_status (owner_type, owner_id, status)",
      "idx_free_nights_rewards_idempotency (source, source_id, owner_type, owner_id)"
    ],
    "bookings": [
      "idx_bookings_package_id (package_id)",
      "idx_bookings_package_status (package_id, status)"
    ]
  },
  "notes": [
    "Schema snapshot generated by verification program",
    "Function calculate_booking_commission_after_insert uses bookings.hotel_id and numeric commission_usd"
  ]
}